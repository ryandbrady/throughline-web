# Throughline Web — environment config. Copy to `.env` and fill in:
#   cp .env.example .env
# `.env` is git-ignored; never commit your tokens.

# Figma personal access token — enables visual previews and comment write-back.
# Create one at: https://www.figma.com/developers/api#access-tokens
# Previews need "File content: Read-only".
# Comment write-back additionally needs "Comments: Read and write".
FIGMA_TOKEN=

# Figma file key for visual previews — recommended.
# It is the ABC123 in a URL like https://figma.com/design/ABC123/My-File.
# Set this explicitly: the Bridge plugin often cannot supply it, and a fresh
# clone has no server/real-design.js to fall back on.
FIGMA_FILE_KEY=

# Anthropic API key — OPTIONAL. The web app prompts for this key on first use
# and stores it in the browser, so you normally don't set it here. Set it only
# to provide a shared default for everyone hitting this server (an operator key).
ANTHROPIC_API_KEY=

# Optional: model used for AI descriptions (default claude-opus-4-7).
DESCRIBE_MODEL=claude-opus-4-7

# Optional: HTTP port (default 4400).
PORT=4400
